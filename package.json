{
  "name": "@pingrep/mcp-server",
  "version": "0.1.0",
  "description": "Official PingRep MCP server for AI Representatives. Always on.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "pingrep-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "start": "node dist/cli.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "pingrep",
    "ai-representative",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pingrep/mcp-server.git"
  },
  "homepage": "https://keynodex.com/docs/mcp/installation",
  "author": "PingRep <dev@pingrep.com>",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bugs": {
    "url": "https://github.com/pingrep/mcp-server/issues"
  },
  "publishConfig": {
    "access": "public"
  }
